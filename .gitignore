# musehub-pwsh — .gitignore
# https://github.com/valorisa/musehub-pwsh

# ──────────────────────────────────────────
# Répertoires de données locales (générés à l'exécution)
# ──────────────────────────────────────────
logs/
backups/

# ──────────────────────────────────────────
# Fichier de configuration utilisateur
# (généré par Install-Dependencies.ps1 — contient des chemins locaux)
# ──────────────────────────────────────────
config/musehub-pwsh.json

# ──────────────────────────────────────────
# Rapports générés
# ──────────────────────────────────────────
*.html
*.csv
*.xlsx

# Sauf les rapports de référence dans docs/
!docs/**/*.html

# ──────────────────────────────────────────
# Couverture de code Pester
# ──────────────────────────────────────────
*.xml
!config/schema.json

# ──────────────────────────────────────────
# Windows
# ──────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ──────────────────────────────────────────
# PowerShell
# ──────────────────────────────────────────
# Modules installés localement (doivent être installés via Install-Dependencies.ps1)
Modules/
*.psm1.bak
*.ps1.bak

# ──────────────────────────────────────────
# Éditeurs
# ──────────────────────────────────────────

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains (Rider)
.idea/
*.iml

# ──────────────────────────────────────────
# Divers
# ──────────────────────────────────────────
*.tmp
*.temp
.DS_Store
